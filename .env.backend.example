# 后端环境变量模板
# 复制此文件为 .env 并填写实际值

# Flask 密钥
SECRET_KEY=your-secret-key-here-change-in-production

# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-database-password
MYSQL_DB=vue_admin

# JWT 配置
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24
